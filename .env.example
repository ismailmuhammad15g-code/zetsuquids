# Supabase client keys (Next.js standard names)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase server-side keys
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# AI Configuration
AI_API_KEY=your_ai_api_key
AI_API_URL=https://api.routeway.ai/v1/chat/completions
NEXT_PUBLIC_AI_API_KEY=your_ai_api_key
NEXT_PUBLIC_AI_API_URL=https://api.routeway.ai/v1/chat/completions
VITE_AI_MODEL=grok-2
